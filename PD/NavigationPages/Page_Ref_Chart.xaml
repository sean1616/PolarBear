            <ColumnDefinition />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <Grid Grid.Row="0">
            <Grid.RowDefinitions>
                <RowDefinition />
                <RowDefinition Height="8*" />
            </Grid.RowDefinitions>           
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Viewbox Height="{Binding ActualHeight, ElementName=txt_ref1, Mode=OneWay}">
                    <Ellipse Height="15"
                             Width="15"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top"
                             RenderTransformOrigin="0.708,0.25">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <RadialGradientBrush.RelativeTransform>
                                    <TransformGroup>
                                        <ScaleTransform CenterY="0.5"
                                                        CenterX="0.5" />
                                        <SkewTransform CenterY="0.5"
                                                       CenterX="0.5" />
                                        <RotateTransform CenterY="0.5"
                                                         CenterX="0.5" />
                                        <TranslateTransform X="0.161"
                                                            Y="-0.147" />
                                    </TransformGroup>
                                </RadialGradientBrush.RelativeTransform>
                                <GradientStop Color="White"
                                              Offset="0" />
                                <GradientStop Color="{Binding ref_Color[0].Color}"
                                              Offset="1" />
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Viewbox>
                <Viewbox Margin="5">
                    <TextBlock Name="txt_ref1"
                               Text="Ref1"
                               Foreground="Black"
                               FontFamily="Segoe Print"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center" />
                </Viewbox>
            </StackPanel>
           
            <oxy:Plot Name="Plot_Ref1"
                      Grid.Column="0"
                      Grid.ColumnSpan="2"
                      Grid.Row="1"
                      FontFamily="Segoe Print"
                      IsMouseWheelEnabled="False"
                      MouseLeftButtonDown="Plot_Chart_1_MouseLeftButtonDown">
                <oxy:Plot.Series>
                    <oxy:LineSeries Width="0.3"
                                    StrokeThickness="0.6"
                                    ItemsSource="{Binding Chart_All_DataPoints_ref[0], Mode=OneWay}"
                                    Color="Blue" />
                </oxy:Plot.Series>
            </oxy:Plot>
        </Grid>


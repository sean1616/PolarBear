                   Grid.Row="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="{Binding Int_Fontsize}"
                   FontFamily="Segoe Print"
                   Text="Board ID" />
        <TextBlock Grid.Column="3"

        <Button x:Name="btn_fillBoard" Grid.Column="0"
                Grid.Row="0"
                Style="{StaticResource style_OnlyImage_Btn}"
                Tag="../Resources/save.png"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" Click="btn_saveBoard_Click"/>
